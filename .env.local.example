# ─────────────────────────────────────────────
# Supabase  (from supabase.com → Project → Settings → API)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only, never expose

# ─────────────────────────────────────────────
# Stripe  (from dashboard.stripe.com → Developers → API keys)
# ─────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...                   # from Stripe CLI or dashboard

# ─────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────
# The Supabase Auth email that gets admin access to /admin/*
ADMIN_EMAIL=your@email.com

# ─────────────────────────────────────────────
# Resend  (resend.com → API Keys)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
# Must be a verified domain in Resend. For testing use: onboarding@resend.dev
RESEND_FROM_EMAIL=Sanchamar <concierge@yourdomain.com>

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# Set to your production domain in Vercel (e.g. https://villa-concierge-five.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
